# ---- Required ----

# A UUID identifying the single user of this instance. Generate one with:
#   uuidgen  (macOS/Linux)
#   python -c "import uuid; print(uuid.uuid4())"
# The container auto-seeds a profiles row with this ID on first start.
SELF_HOSTED_USER_ID=

# Bearer token that the OpenClaw agent sends on every /api/mcp request.
# Generate a long random string, e.g.:
#   openssl rand -hex 32
MCP_API_KEY=

# ---- Recommended ----

# Password for the built-in Postgres container. Pick something random.
POSTGRES_PASSWORD=changeme

# ---- Optional ----

# Email stored on the profile row. Only visible to you.
SELF_HOSTED_USER_EMAIL=user@localhost

# Postgres user + db name (change if you know why).
POSTGRES_USER=cadence
POSTGRES_DB=cadence

# ---- Backups ----
# The db-backup sidecar writes pg_dump files to ./backups on the host.
# Defaults: nightly, keep last 14 daily / 4 weekly / 6 monthly backups.
# Schedule accepts standard cron (e.g. "0 3 * * *") or shorthand
# (@daily, @hourly, @every 1h).
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ---- Timezone ----
# IANA timezone for the app (e.g. America/New_York, Europe/Berlin).
# Controls when "today" rolls over for tasks, habits, journal, and briefings.
# TZ=UTC
